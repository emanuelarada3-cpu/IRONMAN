# Servidor
PORT=3000

# Base de datos SQLite
DB_PATH=soldadura.sqlite

# JWT
JWT_SECRET=cambia_este_secreto_por_uno_seguro_en_produccion
JWT_EXPIRES=8h

# Correo SMTP (para envío de OTP)
# IMPORTANTE: Para Gmail, usa App Password, NO tu contraseña normal
# Pasos para Gmail:
# 1. Activa 2FA en myaccount.google.com
# 2. Ve a myaccount.google.com/apppasswords
# 3. Genera una app password para "Mail"
# 4. Copia sin espacios en MAIL_PASS
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu_email@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx

# Admin inicial (se crea automáticamente al iniciar)
# Cambiar estos valores antes de ejecutar por primera vez
ADMIN_EMAIL=admin@soldadurallastunas.cu
ADMIN_PASSWORD=Admin1234!

# Nombre del negocio (en correos y landing)
BUSINESS_NAME=IronMan

# NOTAS:
# - Nunca hacer commit del .env con datos reales
# - JWT_SECRET debe ser único y fuerte
# - Cambiar ADMIN_PASSWORD en producción
# - Las credenciales de correo son críticas para el funcionamiento
